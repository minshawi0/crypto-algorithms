import java.util.Arrays;
import java.util.Scanner;

class LFSR {
    private String initialseed;  // current state of the LFSR (binary string)
    private int[] tapposition;    // tap position for the feedback
    private int numtapposition;   // number of taps

    public LFSR(String seed, int[] tap, int n) {
        this.initialseed = seed;
        this.numtapposition = n;
        this.tapposition = Arrays.copyOf(tap, n); // store the position
    }

    public int step() {   // generates the next bit of the LFSR by calculating the feedback and shifting the initial seed
        int feedback = initialseed.charAt(tapposition[0]) - '0';  // put the value at the first tap position
        for (int i = 1; i < numtapposition; i++) {              // the loop for the 2nd tap to the last
            feedback ^= (initialseed.charAt(tapposition[i]) - '0'); // each tap XOR with the feedback and result is final feedback used to generate the next bit
        }
        initialseed = initialseed.substring(1) + feedback; // shift left and add new bit at the end
        return feedback;
    }

    public String sequence(int bits) { // bits is number that you want to generate
        StringBuilder sequence = new StringBuilder();   // store generated bits
        for (int i = 0; i < bits; i++) {
            sequence.append(step());  // convert bit which is int to string put in the sequence
        }
        return sequence.toString();
    }

    public String EncryptandDecrypt(String text, String keystream) {
        StringBuilder result = new StringBuilder();   // store output ciphertext or plaintext start with empty string and bit by bit
        for (int i = 0; i < text.length(); i++) {  // avoid negative value and get length of input string
            result.append((text.charAt(i) == keystream.charAt(i)) ? '0' : '1');   // XOR: 0 if same, 1 if different
        }
        return result.toString();
    }
}


public class Main {
    public static void main(String[] args) {
        /* Initialize the initial seed and number of the bits that generated and how many taps will used */

        Scanner scanner = new Scanner(System.in);
        String seed;
        int numofbits, numoftaps;

        System.out.print("Enter the initial seed: ");
        seed = scanner.nextLine();

        System.out.print("Enter number of tap position: ");
        numoftaps = scanner.nextInt();

        int[] taps = new int[10];
        System.out.print("Enter tap position: ");
        for (int i = 0; i < numoftaps; i++) {
            taps[i] = scanner.nextInt();
        }

        /* Generate key stream using LFSR
           Encrypt plain text using XOR in the key stream
           Decrypt the cipher text using XOR in the key stream
        */

        System.out.print("Enter the number of the bits to generate? ");
        numofbits = scanner.nextInt();

        LFSR F1 = new LFSR(seed, taps, numoftaps);
        String keystream = F1.sequence(numofbits);
        System.out.println("keystream is: " + keystream);

        scanner.nextLine(); // Consume newline left-over
        System.out.print("Enter the plaintext: ");
        String plaintext = scanner.nextLine();

        String ciphertext = F1.EncryptandDecrypt(plaintext, keystream);
        System.out.println("ciphertext: " + ciphertext);

        String decrypt = F1.EncryptandDecrypt(ciphertext, keystream);
        System.out.println("decrypttext: " + decrypt);

        scanner.close();
    }
}
